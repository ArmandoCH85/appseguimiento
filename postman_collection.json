{
  "info": {
    "name": "appseguimiento API v1 - Mobile Kotlin",
    "description": "API REST para app móvil Kotlin. Multi-tenant con tenant en el path.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost",
      "type": "string"
    },
    {
      "key": "tenant",
      "value": "acme",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"operador@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "auth", "login"]
            },
            "description": "Login de operador. Retorna token Sanctum + datos del usuario."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "auth", "refresh"]
            },
            "description": "Revoca token actual y emite uno nuevo. Rate limit: 30/min."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "auth", "logout"]
            },
            "description": "Revoca el token actual. Responde 204 No Content."
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "me"]
            },
            "description": "Perfil del usuario autenticado. Incluye role y assignments_count."
          }
        }
      ]
    },
    {
      "name": "Forms",
      "item": [
        {
          "name": "List Forms",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/forms",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "forms"]
            },
            "description": "Lista formularios activos. Operadores ven solo asignados."
          }
        },
        {
          "name": "Form Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/forms/{{form_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "forms", "{{form_id}}"]
            },
            "description": "Detalle del formulario + schema. 403 si operador sin asignación activa."
          }
        }
      ],
      "variable": [
        {
          "key": "form_id",
          "value": "",
          "type": "string"
        }
      ]
    },
    {
      "name": "Submissions",
      "item": [
        {
          "name": "List Submissions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/submissions?status=pending_photos",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "submissions"],
              "query": [
                {
                  "key": "status",
                  "value": "pending_photos",
                  "disabled": true
                },
                {
                  "key": "form_id",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Lista submissions paginadas (15/default). Filtros opcionales: status, form_id."
          }
        },
        {
          "name": "Create Submission (Draft)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"form_version_id\": \"\",\n  \"idempotency_key\": \"draft-key-001\",\n  \"status\": \"draft\",\n  \"responses\": {\n    \"observacion\": \"Borrador inicial\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/submissions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "submissions"]
            },
            "description": "Crea submission en borrador. lat/lng/responses opcionales para draft."
          }
        },
        {
          "name": "Create Submission (Complete)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"form_version_id\": \"\",\n  \"idempotency_key\": \"complete-key-001\",\n  \"status\": \"pending_photos\",\n  \"latitude\": -12.046374,\n  \"longitude\": -77.042793,\n  \"responses\": {\n    \"observacion\": \"Todo correcto\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/submissions",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "submissions"]
            },
            "description": "Crea submission completa. lat, lng y responses obligatorios."
          }
        },
        {
          "name": "Get Submission Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/submissions/{{submission_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "submissions", "{{submission_id}}"]
            },
            "description": "Detalle completo con responses. Solo owner o admin."
          }
        },
        {
          "name": "Update Submission",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"pending_photos\",\n  \"latitude\": -12.046374,\n  \"longitude\": -77.042793,\n  \"responses\": {\n    \"observacion\": \"Actualizado\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/submissions/{{submission_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "submissions", "{{submission_id}}"]
            },
            "description": "Actualiza draft o cambia status. Transiciones: draft->pending_photos, pending_photos->draft."
          }
        },
        {
          "name": "Upload Photo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "photo",
                  "type": "file",
                  "src": [],
                  "description": "Archivo de imagen"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/submissions/{{submission_id}}/photos",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "submissions", "{{submission_id}}", "photos"]
            },
            "description": "Sube foto. Responde 202 y encola procesamiento."
          }
        },
        {
          "name": "List Photos",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/submissions/{{submission_id}}/photos",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "submissions", "{{submission_id}}", "photos"]
            },
            "description": "Lista fotos de una submission."
          }
        },
        {
          "name": "Delete Photo",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/submissions/{{submission_id}}/photos/{{media_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "submissions", "{{submission_id}}", "photos", "{{media_id}}"]
            },
            "description": "Elimina foto. Solo owner y status pending_photos. 204 No Content."
          }
        }
      ],
      "variable": [
        {
          "key": "submission_id",
          "value": "",
          "type": "string"
        },
        {
          "key": "media_id",
          "value": "",
          "type": "string"
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Ping",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{{tenant}}/admin/ping",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{{tenant}}", "admin", "ping"]
            },
            "description": "Ping para admin. 403 para otros roles."
          }
        }
      ]
    }
  ]
}
